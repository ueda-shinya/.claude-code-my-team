# ── 環境変数（PC固有・絶対にGitHubに上げない）──────────
.env
*.env

# ── 認証情報（絶対にGitHubに上げない）──────────────────
# Windowsのみ存在。漏洩すると不正利用される
.credentials.json
mcp-needs-auth-cache.json

# サービスアカウントキー等の認証情報ディレクトリ（漏洩すると不正利用される）
credentials/

# LINE WORKS Private Key（漏洩すると不正利用される）
line-works-bot/*.key
line-works-bot/*.pem

# LINE WORKS Bot ログ
line-works-bot/logs/

# ── Claude Code が自動管理するもの（不要）───────────────
# projects配下はmemory/だけ同期、あとは除外
projects/**
!projects/
!projects/*/
!projects/*/memory/
!projects/*/memory/**
cache/
debug/
downloads/
file-history/
shell-snapshots/
session-env/
telemetry/
backups/
plans/
todos/
ide/
plugins/

# ── 設定ファイル（秘密情報の可能性）────────────────────
settings.json
settings.local.json
google-oauth-credentials.json
mcp.json
.mcp.json

# ── Python 仮想環境（PC固有・Gitに上げない）────────────────
onedrive-mcp-venv/
*-venv/
.venv/
**/.venv/
**/venv/

# ── Python キャッシュ ────────────────────────────────────
__pycache__/
*.pyc

# ── サンプル・テストコード（PC固有）─────────────────────
sandbox/

# ── 一時ファイル ─────────────────────────────────────────
tmp/

# ── バックアップファイル（git管理外ファイルの編集前バックアップ）───
*.bak.*

# ── OS自動生成 ───────────────────────────────────────────
.DS_Store
Thumbs.db
google-oauth-token*.json
mcp-google-calendar-token.json
history.jsonl
mcp-servers/
